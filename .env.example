VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_PUBLIC_KEY"

# Local deterministic E2E mode. Keep false for real staging/static deploy.
VITE_E2E_MODE="false"

# Optional local authenticated Supabase Storage probe.
# Keep these only in .env.local. Do not commit real values.
SUPABASE_E2E_EMAIL="vf-e2e@example.com"
SUPABASE_E2E_PASSWORD="YOUR_STRONG_LOCAL_E2E_PASSWORD"
