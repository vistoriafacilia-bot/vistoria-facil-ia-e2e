# GEMINI_API_KEY: Secret key for accessing Google's Gemini models.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL where the app is hosted.
# Required for Mercado Pago back_urls and webhook notification_url.
APP_URL="https://MY_APP_URL"

# Mercado Pago Checkout Pro.
# Use sandbox token while testing. Do not commit real production tokens.
MERCADOPAGO_ACCESS_TOKEN="TEST-MY_MERCADOPAGO_ACCESS_TOKEN"

# Firebase / Firestore server-side REST configuration.
# AI Studio/Cloud Run may inject these, but keep them documented for release checks.
FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
FIRESTORE_DATABASE_ID="(default)"
FIREBASE_API_KEY="MY_FIREBASE_WEB_API_KEY"
