{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview",
    "preview": "vite preview",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa:rc": "node scripts/qa-release-gate.mjs",
    "test:ci": "vitest run --reporter=verbose --pool=forks",
    "qa:static": "node scripts/qa-release-gate.mjs",
    "qa:staging": "node scripts/qa-staging-readiness.mjs",
    "qa:performance": "node scripts/qa-performance-budget.mjs",
    "qa:supabase-storage-auth": "node scripts/validate-supabase-storage-auth.mjs",
    "qa:uat-real-public": "node scripts/run-real-public-auth-signup-journey.mjs",
    "qa:uat-manual-regression": "node scripts/run-manual-uat-regression.mjs",
    "qa:uat-full-regression": "node scripts/run-uat-full-regression.mjs",
    "qa:uat-ai-smoke": "node scripts/run-uat-ai-smoke.mjs",
    "qa:uat-core-discovery": "node scripts/run-uat-real-complete.mjs --mode=core-discovery",
    "qa:uat-core-certification": "node scripts/run-uat-real-complete.mjs --mode=core-certification",
    "qa:uat-ai-controlled": "node scripts/run-uat-ai-controlled-contract.mjs",
    "qa:production-certification": "node scripts/run-production-certification-contract.mjs",
    "qa:privacy-guard": "node scripts/run-privacy-guard.mjs",
    "qa:uat-real-complete": "node scripts/run-uat-real-complete.mjs",
    "e2e:local": "playwright test --config=playwright.config.ts",
    "e2e:staging": "npm run qa:supabase-storage-auth",
    "e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "e2e:report": "playwright show-report",
    "qa:local-e2e": "npm run lint && npm run test:ci && npm run build && npm run e2e:local",
    "qa:staging-real": "npm run lint && npm run test:ci && npm run build && npm run qa:supabase-storage-auth"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
