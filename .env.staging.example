# Public staging URL after controlled static deploy.
STAGING_BASE_URL="https://YOUR_STATIC_STAGING_URL"

# Supabase Free staging project. Use anon public key only.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_PUBLIC_KEY"

# E2E staging technical user. Keep real values only in .env.local or platform secrets.
SUPABASE_E2E_EMAIL="vf-e2e-staging@example.com"
SUPABASE_E2E_PASSWORD="YOUR_STRONG_STAGING_ONLY_PASSWORD"
STAGING_TEST_RUN_ID="manual"

# GitHub Actions secrets/variables, not committed env values:
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY = static build environment.
# SUPABASE_E2E_EMAIL / SUPABASE_E2E_PASSWORD = authenticated storage probe user.
# STAGING_BASE_URL / STAGING_TEST_RUN_ID = optional controlled staging run metadata.
