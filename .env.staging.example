# Public staging URL after controlled deploy.
STAGING_BASE_URL="https://YOUR_STAGING_HOSTING_URL"

# Firebase staging project used by CI deploy.
FIREBASE_PROJECT_ID_STAGING="YOUR_FIREBASE_STAGING_PROJECT_ID"
FIRESTORE_DATABASE_ID="(default)"
FIREBASE_API_KEY="YOUR_FIREBASE_WEB_API_KEY"
FIREBASE_STORAGE_BUCKET="YOUR_FIREBASE_STORAGE_BUCKET"

# Server-side secrets for staging only.
GEMINI_API_KEY="YOUR_STAGING_GEMINI_API_KEY"
MERCADOPAGO_ACCESS_TOKEN="TEST-YOUR_MERCADO_PAGO_SANDBOX_TOKEN"

# E2E staging technical user. Must exist in Firebase Auth with Email/Password enabled.
STAGING_E2E_EMAIL="vf-e2e-staging@example.com"
STAGING_E2E_PASSWORD="YOUR_STRONG_STAGING_ONLY_PASSWORD"
STAGING_TEST_RUN_ID="manual"

# Cloud Run staging API target.
CLOUD_RUN_REGION="southamerica-east1"
CLOUD_RUN_SERVICE="vistoria-facil-api-staging"

# GitHub Actions secrets/variables, not committed env values:
# GCP_SERVICE_ACCOUNT_STAGING = full JSON service account or WIF-equivalent credential with deploy access.
# FIREBASE_SERVICE_ACCOUNT_STAGING = accepted legacy alias when GCP_SERVICE_ACCOUNT_STAGING is not configured.
# STAGING_E2E_EMAIL / STAGING_E2E_PASSWORD = same technical user credentials in GitHub environment secrets.
# CLOUD_RUN_REGION / CLOUD_RUN_SERVICE = GitHub environment variables when overriding defaults.
